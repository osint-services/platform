# Copy this file to .env and fill in the required values before running docker compose.

# profile_search: X API v2 bearer token used by the Tweepy client.
# Create it in an X Developer Portal project/app. Keep it secret.
TWEEPY_BEARER_TOKEN=your_tweepy_bearer_token

# phone_search: Twilio API credentials from the Twilio Console.
# The Account SID normally starts with AC. Keep the auth token secret.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# dataset_service: Compose already persists this path in the dataset_data volume.
# Override only when you intentionally want a different in-container location.
# DATASET_DB_PATH=/data/datasets.db
